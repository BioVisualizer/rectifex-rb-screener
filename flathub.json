{
    "app-id": "com.rectifex.GlobalReboundScreener",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.7",
    "sdk": "org.kde.Sdk",
    "command": "python3",
    "args": ["-u", "main.py"],
    "finish-args": [
        "--share=network",
        "--filesystem=home",
        "--device=dri"
    ],
    "modules": [
        {
            "name": "python-requirements",
            "buildsystem": "pip",
            "build-options": {
                "build-args": [
                    "--share=network"
                ]
            },
            "sources": [
                {
                    "type": "file",
                    "path": "requirements.txt"
                }
            ]
        },
        {
            "name": "rectifex-rb",
            "buildsystem": "simple",
            "build-commands": [
                "install -D main.py /app/main.py",
                "install -D ui.py /app/ui.py",
                "install -D analysis.py /app/analysis.py",
                "install -D data_loader.py /app/data_loader.py",
                "install -D config.py /app/config.py",
                "cp -r data /app/"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
